{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "sessionEnd": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "beforeSubmitPrompt": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "afterAgentResponse": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "preToolUse": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "postToolUse": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "postToolUseFailure": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "subagentStart": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ],
    "subagentStop": [
      {"command": "$HOME/.local/share/dash0-agent-plugin/cursor-on-event.sh"}
    ]
  }
}
