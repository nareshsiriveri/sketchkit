{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-dep-install.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-manifest-edit.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/suggest-endor-tools.sh\"",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
