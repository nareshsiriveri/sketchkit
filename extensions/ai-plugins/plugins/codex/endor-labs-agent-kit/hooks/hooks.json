{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"${PLUGIN_ROOT}/hooks/check-dep-install.sh\" PostToolUse",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash \"${PLUGIN_ROOT}/hooks/check-manifest-edit.sh\" PostToolUse",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "apply_patch|Edit|Write"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash \"${PLUGIN_ROOT}/hooks/suggest-endor-tools.sh\" UserPromptSubmit",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
